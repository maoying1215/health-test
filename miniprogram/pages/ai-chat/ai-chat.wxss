.chat-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 顶部标题栏 */
.chat-header {
  background: linear-gradient(135deg, #94b088 0%, #a0d6e4 100%);
  padding: 40rpx 30rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 聊天消息区域 */
.chat-messages {
  flex: 1;
  padding: 20rpx;
  overflow-y: scroll;
}

.message-item {
  margin-bottom: 30rpx;
}

/* AI消息样式 */
.message-ai {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
}

.avatar-ai {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #AAC676 0%, #aaC676 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.message-content-ai {
  max-width: 70%;
  background: white;
  padding: 24rpx;
  border-radius: 0 20rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 用户消息样式 */
.message-user {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
}

.avatar-user {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #10B981;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.message-content-user {
  max-width: 70%;
  background: #10B981;
  padding: 24rpx;
  border-radius: 20rpx 0 20rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.message-content-user .message-text {
  color: white;
}

.message-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  word-wrap: break-word;
}

.message-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.message-content-user .message-time {
  color: rgba(255, 255, 255, 0.8);
}

/* 打字中指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.typing-dots {
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 0 20rpx 20rpx 20rpx;
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10B981;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.5;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

/* 快捷问题 */
.quick-questions {
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #e5e5e5;
}

.quick-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.quick-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.quick-btn {
  padding: 16rpx 28rpx;
  background: #f0f0f0;
  border: 1rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #333;
}

.quick-btn:active {
  background: #e8e8e8;
}

/* 底部输入栏 */
.chat-input-area {
  background: white;
  padding: 20rpx;
  border-top: 1rpx solid #e5e5e5;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.chat-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.send-btn[disabled] {
  background: #ccc;
  opacity: 0.6;
}
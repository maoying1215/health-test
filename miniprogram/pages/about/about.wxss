.logo-card {
  background: linear-gradient(135deg, #94b088, #a0d6e4);
  text-align: center;
  padding: 60rpx 40rpx;
}

.app-logo { font-size: 120rpx; display: block; margin-bottom: 20rpx; }
.app-name { font-size: 44rpx; font-weight: bold; color: white; display: block; margin-bottom: 10rpx; }
.app-version { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-bottom: 16rpx; }
.app-slogan { font-size: 28rpx; color: rgba(255,255,255,0.95); }

.section-title { font-size: 28rpx; color: #999; display: block; margin-bottom: 20rpx; }

.about-text { font-size: 28rpx; color: #555; line-height: 1.8; }

.feature-list { margin-top: 10rpx; }

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child { border-bottom: none; }

.feature-icon { font-size: 44rpx; margin-right: 20rpx; }
.feature-info { flex: 1; }
.feature-name { font-size: 30rpx; color: #333; display: block; margin-bottom: 6rpx; }
.feature-desc { font-size: 24rpx; color: #999; }

.info-list { margin-top: 10rpx; }

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child { border-bottom: none; }

.info-label { font-size: 28rpx; color: #666; }
.info-value { font-size: 28rpx; color: #333; }

.action-list { margin-top: 10rpx; }

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child { border-bottom: none; }

.action-left { display: flex; align-items: center; }
.action-icon { font-size: 40rpx; margin-right: 20rpx; }
.action-name { font-size: 30rpx; color: #333; }
.arrow { font-size: 48rpx; color: #ccc; }

.footer {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #ccc;
  display: block;
  margin-bottom: 10rpx;
}

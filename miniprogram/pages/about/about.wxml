<view class="container">
  <!-- Logo区域 -->
  <view class="card logo-card">
    <view class="app-logo">🌿</view>
    <text class="app-name">健康助手</text>
    <text class="app-version">版本 {{version}}</text>
    <text class="app-slogan">关注健康，享受生活</text>
  </view>

  <!-- 应用介绍 -->
  <view class="card">
    <text class="section-title">关于应用</text>
    <text class="about-text">
      健康助手是一款专注于个人健康管理的小程序，帮助您追踪健康数据、制定健康目标、获取专业健康建议，养成良好的生活习惯。
    </text>
  </view>

  <!-- 核心功能 -->
  <view class="card">
    <text class="section-title">核心功能</text>
    <view class="feature-list">
      <view class="feature-item" wx:for="{{features}}" wx:key="name">
        <text class="feature-icon">{{item.icon}}</text>
        <view class="feature-info">
          <text class="feature-name">{{item.name}}</text>
          <text class="feature-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="card">
    <text class="section-title">版本信息</text>
    <view class="info-list">
      <view class="info-row" wx:for="{{versionInfo}}" wx:key="label">
        <text class="info-label">{{item.label}}</text>
        <text class="info-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 操作项 -->
  <view class="card">
    <view class="action-list">
      <view class="action-item" bindtap="checkUpdate">
        <view class="action-left">
          <text class="action-icon">🔄</text>
          <text class="action-name">检查更新</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item" bindtap="rateApp">
        <view class="action-left">
          <text class="action-icon">⭐</text>
          <text class="action-name">给我们评分</text>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item" bindtap="shareApp">
        <view class="action-left">
          <text class="action-icon">📤</text>
          <text class="action-name">分享给朋友</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">© 2025 健康助手团队</text>
    <text class="footer-text">用❤️为您打造</text>
  </view>
</view>

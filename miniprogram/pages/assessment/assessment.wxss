.assessment-types {
  margin-top: 30rpx;
}

.type-card {
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-card.active {
  border-color: #4A90E2;
  background: #E5F5FF;
}

.type-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 15rpx;
}

.type-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.type-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  line-height: 1.5;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress {
  height: 100%;
  background: linear-gradient(90deg, #4A90E2 0%, #667eea 100%);
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
}

.question-card {
  padding: 30rpx 0;
}

.question-title {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 30rpx;
  font-weight: 500;
}

.options {
  margin-top: 30rpx;
}

.option-item {
  padding: 25rpx 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-item.selected {
  border-color: #4A90E2;
  background: #E5F5FF;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.button-group button {
  flex: 1;
  margin: 0;
}

.result-header {
  text-align: center;
  padding: 40rpx 0;
}

.result-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.result-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx;
  border-radius: 16rpx;
  text-align: center;
  color: white;
  margin: 30rpx 0;
}

.result-label {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 20rpx;
}

.result-score {
  font-size: 80rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.result-level {
  font-size: 32rpx;
  display: block;
}

.result-details {
  margin: 30rpx 0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: 500;
}

.advice-section {
  margin: 30rpx 0;
  padding: 30rpx;
  background: #FFF9E5;
  border-radius: 12rpx;
}

.advice-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.advice-number {
  font-size: 28rpx;
  color: #F59E0B;
  margin-right: 10rpx;
  font-weight: bold;
}

.advice-content {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

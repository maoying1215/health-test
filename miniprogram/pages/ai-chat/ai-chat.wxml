<view class="chat-container">
  <!-- 顶部标题栏 -->
  <view class="chat-header">
    <text class="header-title">AI健康助手</text>
    <text class="header-subtitle">心理-代谢健康智能咨询</text>
  </view>

  <!-- 聊天消息区域 -->
  <scroll-view class="chat-messages" scroll-y="true" scroll-into-view="{{scrollToView}}">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}" class="message-item">
      <!-- AI消息 -->
      <view wx:if="{{item.type === 'ai'}}" class="message-ai">
        <view class="avatar-ai">
          <text class="avatar-text">AI</text>
        </view>
        <view class="message-content-ai">
          <text class="message-text">{{item.content}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
      </view>

      <!-- 用户消息 -->
      <view wx:else class="message-user">
        <view class="message-content-user">
          <text class="message-text">{{item.content}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
        <view class="avatar-user">
          <text class="avatar-text">我</text>
        </view>
      </view>
    </view>

    <!-- 加载中提示 -->
    <view wx:if="{{isTyping}}" class="typing-indicator">
      <view class="avatar-ai">
        <text class="avatar-text">AI</text>
      </view>
      <view class="typing-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷问题按钮 -->
  <view wx:if="{{showQuickQuestions}}" class="quick-questions">
    <text class="quick-title">您可以问我:</text>
    <view class="quick-buttons">
      <button 
        wx:for="{{quickQuestions}}" 
        wx:key="index" 
        class="quick-btn" 
        bindtap="sendQuickQuestion" 
        data-question="{{item}}">
        {{item}}
      </button>
    </view>
  </view>

  <!-- 底部输入栏 -->
  <view class="chat-input-area">
    <view class="input-wrapper">
      <input 
        class="chat-input" 
        placeholder="请输入您的健康问题..." 
        value="{{inputText}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="sendMessage"
      />
      <button class="send-btn" bindtap="sendMessage" disabled="{{!inputText}}">
        发送
      </button>
    </view>
  </view>
</view>
.loading-container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #73AE52 0%, #FBF1D7 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
  background: white;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 40rpx;
}

.app-name {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.loading-progress {
  position: absolute;
  bottom: 150rpx;
  width: 70%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.progress-fill {
  height: 100%;
  background: white;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 如果使用文字 logo 而不是图片 */
.logo-text {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
  background: white;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #C3EDC9;
  font-weight: bold;
}
<view class="container">
  <!-- 评估类型选择 -->
  <view class="card" wx:if="{{!assessmentStarted}}">
    <text class="title">选择评估类型</text>
    <view class="assessment-types">
      <view class="type-card {{selectedType === 'psychological' ? 'active' : ''}}" 
            bindtap="selectType" data-type="psychological">
        <text class="type-icon">🧠</text>
        <text class="type-title">心理健康评估</text>
        <text class="type-desc">评估情绪状态、压力水平、睡眠质量等</text>
      </view>
      <view class="type-card {{selectedType === 'metabolic' ? 'active' : ''}}" 
            bindtap="selectType" data-type="metabolic">
        <text class="type-icon">💪</text>
        <text class="type-title">代谢健康评估</text>
        <text class="type-desc">评估体重、血糖、血压、运动等指标</text>
      </view>
      <view class="type-card {{selectedType === 'comprehensive' ? 'active' : ''}}" 
            bindtap="selectType" data-type="comprehensive">
        <text class="type-icon">📋</text>
        <text class="type-title">综合健康评估</text>
        <text class="type-desc">全面评估心理和代谢健康状况</text>
      </view>
    </view>
    <button class="btn-primary" bindtap="startAssessment">开始评估</button>
  </view>

  <!-- 问卷评估 -->
  <view class="card" wx:if="{{assessmentStarted && !showResult}}">
    <view class="progress-bar">
      <view class="progress" style="width: {{progress}}"></view>
    </view>
    <text class="progress-text">{{currentIndex + 1}} / {{questions.length}}</text>

    <view class="question-card">
      <text class="question-title">{{currentQuestion.question}}</text>
      <view class="options">
        <view class="option-item {{selectedOption === index ? 'selected' : ''}}" 
              wx:for="{{currentQuestion.options}}" 
              wx:key="index"
              bindtap="selectOption" 
              data-index="{{index}}">
          <text class="option-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="button-group">
      <button class="btn-secondary" wx:if="{{currentIndex > 0}}" bindtap="previousQuestion">上一题</button>
      <button class="btn-primary" bindtap="nextQuestion">{{currentIndex === questions.length - 1 ? '完成' : '下一题'}}</button>
    </view>
  </view>

  <!-- 评估结果 -->
  <view class="card" wx:if="{{showResult}}">
    <view class="result-header">
      <text class="result-icon">✅</text>
      <text class="result-title">评估完成</text>
    </view>

    <view class="result-card">
      <text class="result-label">综合评分</text>
      <text class="result-score">{{totalScore}}</text>
      <text class="result-level">{{scoreLevel}}</text>
    </view>

    <view class="result-details" wx:if="{{selectedType === 'comprehensive' || selectedType === 'psychological'}}">
      <text class="detail-title">心理健康</text>
      <view class="detail-item">
        <text class="detail-label">情绪状态</text>
        <text class="detail-value">{{psychologicalDetails.emotion}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">压力水平</text>
        <text class="detail-value">{{psychologicalDetails.stress}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">睡眠质量</text>
        <text class="detail-value">{{psychologicalDetails.sleep}}</text>
      </view>
    </view>

    <view class="result-details" wx:if="{{selectedType === 'comprehensive' || selectedType === 'metabolic'}}">
      <text class="detail-title">代谢健康</text>
      <view class="detail-item">
        <text class="detail-label">体重指数</text>
        <text class="detail-value">{{metabolicDetails.bmi}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">运动水平</text>
        <text class="detail-value">{{metabolicDetails.exercise}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">饮食习惯</text>
        <text class="detail-value">{{metabolicDetails.diet}}</text>
      </view>
    </view>

    <view class="advice-section">
      <text class="advice-title">个性化建议</text>
      <view class="advice-item" wx:for="{{adviceList}}" wx:key="index">
        <text class="advice-number">{{index + 1}}.</text>
        <text class="advice-content">{{item}}</text>
      </view>
    </view>

    <view class="button-group">
      <button class="btn-secondary" bindtap="viewHistory">查看历史</button>
      <button class="btn-primary" bindtap="restart">重新评估</button>
    </view>
  </view>
</view>

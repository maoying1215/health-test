.assessment-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
}

/* 类型选择页面 */
.type-selection {
  padding: 40rpx;
}

.welcome-text {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.type-cards {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.type-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.type-card.active {
  border-color: #a7d6b5;
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
}

.card-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.start-btn {
  width: 100%;
  background: linear-gradient(135deg, #b2e5a1 0%, #89bb8e 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 评估进行中 */
.assessment-progress {
  padding: 20rpx;
}

.progress-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.exit-text {
  font-size: 26rpx;
  color: #a7d6b5;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #b2e5a1 0%, #89bb8e 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.section-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.section-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #a7d6b5;
}

/* 问题卡片 */
.question-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.question-number {
  font-size: 24rpx;
  color: #a7d6b5;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 40rpx;
  font-weight: 500;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #f9fafb;
  border-radius: 15rpx;
  border: 2rpx solid #e5e7eb;
  transition: all 0.2s;
}

.option-item.selected {
  background: #f0fdf4;
  border-color: #a7d6b5;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d1d5db;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-item.selected .option-radio {
  border-color: #a7d6b5;
}

.option-radio-checked {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #a7d6b5;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 导航按钮 */
.nav-buttons {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx;
}

.nav-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.prev-btn {
  background: #f3f4f6;
  color: #666;
}

.next-btn {
  background: linear-gradient(135deg, #b2e5a1 0%, #89bb8e 100%);
  color: white;
}

.next-btn[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

/* 结果页面 */
.result-container {
  padding: 20rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.result-section {
  margin-bottom: 30rpx;
}

.score-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.score-item:last-child {
  border-bottom: none;
}

.score-label {
  font-size: 28rpx;
  color: #666;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #a7d6b5;
  margin: 0 20rpx;
}

.score-level {
  font-size: 26rpx;
  color: #666;
  background: #f0fdf4;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.overall-score {
  background: linear-gradient(135deg, #b2e5a1 0%, #89bb8e 100%);
  border-radius: 20rpx;
  padding: 50rpx;
  text-align: center;
  color: white;
  position: relative;
}

.overall-label {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.overall-value {
  display: block;
  font-size: 80rpx;
  font-weight: bold;
}

.score-ring {
  margin-top: 10rpx;
}

.ring-text {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 建议部分 */
.advice-section {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.advice-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  line-height: 1.6;
}

.advice-icon {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  background: #a7d6b5;
  color: white;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.advice-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 20rpx;
}

.action-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg,#b2e5a1 0%, #89bb8e 100%);
  color: white;
}

.action-btn.secondary {
  background: #f3f4f6;
  color: #666;
}
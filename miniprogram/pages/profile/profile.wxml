<view class="container">
  <!-- 用户信息卡片 -->
  <view class="card user-card">
    <view class="user-header">
      <view class="user-avatar-large">{{userName.charAt(0)}}</view>
      <view class="user-info">
        <text class="user-name">{{userName}}</text>
        <text class="user-desc">保持健康,享受生活</text>
      </view>
      <button class="edit-btn" bindtap="editProfile">编辑</button>
    </view>
  </view>

  <!-- 健康统计 -->
  <view class="card stats-card">
    <text class="title">健康统计</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{assessmentCount}}</text>
        <text class="stat-label">评估次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{dataRecordCount}}</text>
        <text class="stat-label">数据记录</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{continuousDays}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPage" data-page="reminder">
        <view class="menu-left">
          <text class="menu-icon">⏰</text>
          <text class="menu-text">健康提醒</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-page="report">
        <view class="menu-left">
          <text class="menu-icon">📊</text>
          <text class="menu-text">健康报告</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-page="goal">
        <view class="menu-left">
          <text class="menu-icon">🎯</text>
          <text class="menu-text">健康目标</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-page="achievements">
        <view class="menu-left">
          <text class="menu-icon">🏆</text>
          <text class="menu-text">成就徽章</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPage" data-page="privacy">
        <view class="menu-left">
          <text class="menu-icon">🔒</text>
          <text class="menu-text">隐私设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-page="notification">
        <view class="menu-left">
          <text class="menu-icon">🔔</text>
          <text class="menu-text">通知设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-page="help">
        <view class="menu-left">
          <text class="menu-icon">❓</text>
          <text class="menu-text">帮助与反馈</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToPage" data-page="about">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="btn-secondary logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
